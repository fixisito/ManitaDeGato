@{
    ViewData["Title"] = "Inicio";
}

<div class="relative rounded-3xl overflow-hidden neo-card mb-12 p-8 md:p-16">
    <!-- Glows de fondo decorativos -->
    <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-pink-500/10 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-48 h-48 rounded-full bg-purple-500/10 blur-3xl pointer-events-none"></div>
    
    <div class="relative z-10">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
            var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value;
            var nameToDisplay = !string.IsNullOrEmpty(displayName) ? displayName : (User.Identity.Name ?? "Usuario");

            <div class="flex flex-col gap-8">
                <!-- Header section of the card -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <div>
                        @if (role == "Administrador")
                        {
                            <h1 class="text-3xl md:text-5xl font-black text-white tracking-tight leading-tight mb-2">
                                Panel de Control <br/>
                                <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                                    Manita de Gato
                                </span>
                            </h1>
                            <p class="text-lg text-gray-400 font-light mt-4">
                                Hola, <span class="text-white font-bold">@nameToDisplay</span>. Desde aquí puedes gestionar estilistas, servicios, categorías y supervisar toda la agenda de citas del salón.
                            </p>
                        }
                        else if (role == "Estilista")
                        {
                            <h1 class="text-3xl md:text-5xl font-black text-white tracking-tight leading-tight mb-2">
                                Espacio de Trabajo <br/>
                                <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                                    Manita de Gato
                                </span>
                            </h1>
                            <p class="text-lg text-gray-400 font-light mt-4">
                                Hola, <span class="text-white font-bold">@nameToDisplay</span>. Revisa tu agenda de citas para hoy, administra tus servicios ofrecidos o ajusta tus horarios.
                            </p>
                        }
                        else
                        {
                            <h1 class="text-3xl md:text-5xl font-black text-white tracking-tight leading-tight mb-2">
                                Tu Portal de Belleza <br/>
                                <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                                    Manita de Gato
                                </span>
                            </h1>
                            <p class="text-lg text-gray-400 font-light mt-4">
                                Hola, <span class="text-white font-bold">@nameToDisplay</span>. Qué bueno tenerte de vuelta. Agenda tu próxima cita con tu estilista preferido o revisa tu historial de atenciones.
                            </p>
                        }
                    </div>
                    
                    @if (role == "Administrador")
                    {
                        <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0 shadow-sm">
                            <i class="fa-solid fa-shield-halved text-pink-500"></i>
                            <span class="text-pink-500 font-bold text-xs tracking-wider uppercase">Administrador</span>
                        </div>
                    }
                    else if (role == "Estilista")
                    {
                        <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0 shadow-sm">
                            <i class="fa-solid fa-scissors text-pink-500"></i>
                            <span class="text-pink-500 font-bold text-xs tracking-wider uppercase">Estilista</span>
                        </div>
                    }
                    else if (role == "Cliente")
                    {
                        <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0 shadow-sm">
                            <i class="fa-solid fa-heart text-pink-500"></i>
                            <span class="text-pink-500 font-bold text-xs tracking-wider uppercase">Cliente</span>
                        </div>
                    }
                </div>

                <div class="w-full h-px bg-gray-200 dark:bg-gray-800/50"></div>

                <!-- Quick Access Grid -->
                <div>
                    <h2 class="text-xs text-gray-500 dark:text-gray-400 font-semibold tracking-wider mb-6 uppercase">Accesos Rápidos</h2>
                    
                    @if (role == "Administrador")
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                            <a asp-controller="Estilistas" asp-action="Index" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-users text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Estilistas</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Gestiona tu equipo de profesionales y sus horarios de disponibilidad.
                                </p>
                            </a>
                            <a asp-controller="Servicios" asp-action="Index" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-bell-concierge text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Servicios</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Administra el catálogo de servicios, precios y duraciones.
                                </p>
                            </a>
                            <a asp-controller="Categorias" asp-action="Index" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-layer-group text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Categorías</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Organiza los servicios por especialidades o tipos de atención.
                                </p>
                            </a>
                            <a asp-controller="Citas" asp-action="Index" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-calendar-days text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Agenda</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Supervisa y gestiona la programación de todas las citas del salón.
                                </p>
                            </a>
                        </div>
                    }
                    else if (role == "Estilista")
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <a asp-controller="Servicios" asp-action="MisServicios" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-bell-concierge text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Mis Servicios</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Revisa las especialidades y servicios que tienes habilitados.
                                </p>
                            </a>
                            <a asp-controller="Citas" asp-action="MisCitas" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-calendar-check text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Mi Agenda</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Gestiona tu agenda personal de citas asignadas para hoy y el futuro.
                                </p>
                            </a>
                        </div>
                    }
                    else if (role == "Cliente")
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <a asp-controller="Citas" asp-action="Agendar" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-calendar-plus text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Agendar Cita</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Reserva tu hora seleccionando tu categoría, estilista y servicio ideal.
                                </p>
                            </a>
                            <a asp-controller="Citas" asp-action="Historial" class="flex flex-col items-start p-6 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                                <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                                    <i class="fa-solid fa-clock-rotate-left text-pink-500 text-lg"></i>
                                </div>
                                <div class="flex items-center w-full mb-1">
                                    <span class="text-base font-bold text-gray-800 dark:text-white">Mi Historial</span>
                                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 group-hover:translate-x-1 transition-all"></i>
                                </div>
                                <p class="text-xs text-gray-400 font-light leading-relaxed">
                                    Revisa el estado de tus citas pasadas y próximas reservas.
                                </p>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-4">
                <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight leading-none mb-4">
                    Te damos la bienvenida a <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                        Manita de Gato
                    </span>
                </h1>
                
                <p class="text-lg text-gray-400 max-w-2xl font-light tracking-wide mb-6">
                    Hola, te invitamos a gestionar tus citas y servicios de belleza a través de nuestra plataforma optimizada. Inicia sesión o crea una cuenta para comenzar.
                </p>

                <div class="flex flex-wrap gap-4 mt-4">
                    <a asp-controller="Auth" asp-action="Login" class="px-8 py-4 bg-pink-600 text-real-white font-bold tracking-wide rounded-xl hover:bg-pink-700 transition-all shadow-[0_0_20px_rgba(236,72,153,0.3)] hover:shadow-[0_0_25px_rgba(236,72,153,0.5)] transform hover:-translate-y-0.5 flex items-center gap-2">
                        Iniciar Sesión <i class="fa-solid fa-arrow-right text-sm"></i>
                    </a>
                    <a asp-controller="Auth" asp-action="Registro" class="px-8 py-4 bg-transparent border border-gray-300 dark:border-gray-700 rounded-xl text-gray-700 dark:text-gray-300 font-bold tracking-wide hover:border-pink-500 hover:text-pink-500 transition-all transform hover:-translate-y-0.5">
                        Crear Cuenta
                    </a>
                </div>
            </div>
        }
    </div>
</div>

