@{
    ViewData["Title"] = "Inicio";
}

<div class="relative rounded-3xl overflow-hidden neo-card mb-12 p-8 md:p-16">
    <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-none mb-6 uppercase">
        BIENVENIDO A <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
            MANITA DE GATO
        </span>
    </h1>
    
    <p class="text-lg text-gray-400 max-w-2xl font-light tracking-wide mb-8">
        Hola <span class="text-white font-bold">@(User.Identity?.IsAuthenticated == true ? User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value : "INVITADO")</span>. GESTIONA TUS CITAS Y SERVICIOS CON NUESTRA NUEVA PLATAFORMA OPTIMIZADA.
    </p>

    @if (!(User.Identity != null && User.Identity.IsAuthenticated))
    {
        <div class="flex flex-wrap gap-4 mt-8">
            <a asp-controller="Auth" asp-action="Login" class="px-8 py-4 bg-pink-600 text-real-white font-black tracking-widest uppercase hover:bg-pink-700 transition-colors shadow-[0_0_20px_rgba(236,72,153,0.3)]">
                INICIAR SESIÓN <i class="fa-solid fa-arrow-right ml-2"></i>
            </a>
            <a asp-controller="Auth" asp-action="Registro" class="px-8 py-4 bg-transparent border border-gray-600 text-gray-300 font-black tracking-widest uppercase hover:border-white hover:text-white transition-colors">
                CREAR CUENTA
            </a>
        </div>
    }
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
    var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value;

    if (role == "Administrador")
    {
        <div class="neo-card p-8 md:p-10">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-shield-halved text-xl text-pink-400"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-white tracking-tight uppercase">Bienvenido, Administrador</h2>
                    <p class="text-sm text-gray-400 font-mono tracking-wide">PANEL DE ACCESO RÁPIDO</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <a asp-controller="Estilistas" asp-action="Index" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-users text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Estilistas</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
                <a asp-controller="Servicios" asp-action="Index" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-bell-concierge text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Servicios</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
                <a asp-controller="Categorias" asp-action="Index" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-layer-group text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Categorías</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
                <a asp-controller="Citas" asp-action="Index" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-calendar-days text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Agenda</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
            </div>
        </div>
    }
    else if (role == "Estilista")
    {
        <div class="neo-card p-8 md:p-10">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-scissors text-xl text-pink-400"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-white tracking-tight uppercase">Bienvenido, @displayName</h2>
                    <p class="text-sm text-gray-400 font-mono tracking-wide">TU ESPACIO DE TRABAJO</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a asp-controller="Servicios" asp-action="MisServicios" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-bell-concierge text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Mis Servicios</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
                <a asp-controller="Citas" asp-action="MisCitas" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-calendar-check text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Mi Agenda</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
            </div>
        </div>
    }
    else if (role == "Cliente")
    {
        <div class="neo-card p-8 md:p-10">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-heart text-xl text-pink-400"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-black text-white tracking-tight uppercase">Bienvenido, @displayName</h2>
                    <p class="text-sm text-gray-400 font-mono tracking-wide">TU ESPACIO PERSONAL</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a asp-controller="Citas" asp-action="Agendar" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-calendar-plus text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Agendar Cita</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
                <a asp-controller="Citas" asp-action="Historial" class="flex items-center gap-4 p-4 rounded-xl bg-pink-500/10 hover:bg-pink-500/20 transition-colors group">
                    <i class="fa-solid fa-clock-rotate-left text-pink-400 text-lg"></i>
                    <span class="text-sm font-bold text-white tracking-wide uppercase">Mi Historial</span>
                    <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-400 transition-colors"></i>
                </a>
            </div>
        </div>
    }
}
