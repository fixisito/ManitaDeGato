@{
    ViewData["Title"] = "Inicio";
}

<div class="relative rounded-3xl overflow-hidden neo-card mb-12 p-8 md:p-16">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
        var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value;

        <div class="flex flex-col gap-8">
            <!-- Header section of the card -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-3xl md:text-5xl font-black text-white tracking-tighter leading-tight mb-2 uppercase">
                        BIENVENIDO A <br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                            MANITA DE GATO
                        </span>
                    </h1>
                    <p class="text-lg text-gray-400 font-light tracking-wide mt-4">
                        Hola <span class="text-white font-bold">@displayName</span>. Gestiona tus citas y servicios con nuestra plataforma optimizada.
                    </p>
                </div>
                
                @if (role == "Administrador")
                {
                    <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0">
                        <i class="fa-solid fa-shield-halved text-pink-500"></i>
                        <span class="text-pink-500 font-bold text-sm tracking-widest uppercase">Administrador</span>
                    </div>
                }
                else if (role == "Estilista")
                {
                    <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0">
                        <i class="fa-solid fa-scissors text-pink-500"></i>
                        <span class="text-pink-500 font-bold text-sm tracking-widest uppercase">Estilista</span>
                    </div>
                }
                else if (role == "Cliente")
                {
                    <div class="flex items-center gap-3 px-4 py-2 bg-pink-500/10 rounded-full border border-pink-500/20 w-fit md:self-start mt-2 md:mt-0">
                        <i class="fa-solid fa-heart text-pink-500"></i>
                        <span class="text-pink-500 font-bold text-sm tracking-widest uppercase">Cliente</span>
                    </div>
                }
            </div>

            <div class="w-full h-px bg-gray-200 dark:bg-gray-800"></div>

            <!-- Quick Access Grid -->
            <div>
                <h2 class="text-sm text-gray-500 dark:text-gray-400 font-mono tracking-widest mb-6 uppercase">Accesos Rápidos</h2>
                
                @if (role == "Administrador")
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                        <a asp-controller="Estilistas" asp-action="Index" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-users text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Estilistas</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                        <a asp-controller="Servicios" asp-action="Index" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-bell-concierge text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Servicios</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                        <a asp-controller="Categorias" asp-action="Index" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-layer-group text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Categorías</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                        <a asp-controller="Citas" asp-action="Index" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-calendar-days text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Agenda</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                    </div>
                }
                else if (role == "Estilista")
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <a asp-controller="Servicios" asp-action="MisServicios" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-bell-concierge text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Mis Servicios</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                        <a asp-controller="Citas" asp-action="MisCitas" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-calendar-check text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Mi Agenda</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                    </div>
                }
                else if (role == "Cliente")
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <a asp-controller="Citas" asp-action="Agendar" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-calendar-plus text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Agendar Cita</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                        <a asp-controller="Citas" asp-action="Historial" class="flex items-center gap-4 p-5 rounded-2xl bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-gray-800 hover:border-pink-500/50 hover:bg-pink-500/5 transition-all group shadow-sm">
                            <div class="w-10 h-10 rounded-full bg-pink-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-clock-rotate-left text-pink-500 text-lg"></i>
                            </div>
                            <span class="text-sm font-bold text-gray-800 dark:text-white tracking-wide">Mi Historial</span>
                            <i class="fa-solid fa-arrow-right ml-auto text-gray-400 group-hover:text-pink-500 transition-colors"></i>
                        </a>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-none mb-6 uppercase">
            BIENVENIDO A <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-600">
                MANITA DE GATO
            </span>
        </h1>
        
        <p class="text-lg text-gray-400 max-w-2xl font-light tracking-wide mb-8">
            Hola <span class="text-white font-bold">INVITADO</span>. GESTIONA TUS CITAS Y SERVICIOS CON NUESTRA NUEVA PLATAFORMA OPTIMIZADA.
        </p>

        <div class="flex flex-wrap gap-4 mt-8">
            <a asp-controller="Auth" asp-action="Login" class="px-8 py-4 bg-pink-600 text-real-white font-black tracking-widest uppercase rounded-xl hover:bg-pink-700 transition-colors shadow-[0_0_20px_rgba(236,72,153,0.3)]">
                INICIAR SESIÓN <i class="fa-solid fa-arrow-right ml-2"></i>
            </a>
            <a asp-controller="Auth" asp-action="Registro" class="px-8 py-4 bg-transparent border border-gray-600 rounded-xl text-gray-800 dark:text-gray-300 font-black tracking-widest uppercase hover:border-pink-500 hover:text-pink-500 transition-colors">
                CREAR CUENTA
            </a>
        </div>
    }
</div>
