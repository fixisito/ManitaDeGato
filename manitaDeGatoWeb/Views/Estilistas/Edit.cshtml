@model manitaDeGatoWeb.Models.Estilista

@{
    ViewData["Title"] = "Editar Estilista";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-pink-500 hover:text-pink-600 flex items-center gap-2 font-medium">
            <i class="fa-solid fa-arrow-left"></i> Volver a estilistas
        </a>
    </div>

    <div class="neo-card rounded-2xl shadow-md border border-gray-800 p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-pink-900/20 rounded-bl-full -z-10"></div>
        
        <h1 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <div class="bg-pink-100 text-pink-500 p-2 rounded-lg">
                <i class="fa-solid fa-user-pen"></i>
            </div>
            Editar Profesional
        </h1>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Nombre" class="block text-sm font-medium text-gray-300 mb-1">Nombre</label>
                    <input asp-for="Nombre" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Apellido" class="block text-sm font-medium text-gray-300 mb-1">Apellido</label>
                    <input asp-for="Apellido" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Usuario" class="block text-sm font-medium text-gray-300 mb-1">Nombre de Usuario</label>
                    <input asp-for="Usuario" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Contraseña" class="block text-sm font-medium text-gray-300 mb-1">Nueva Contraseña</label>
                    <input asp-for="Contraseña" type="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" placeholder="Dejar en blanco para no cambiarla" />
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-3 border-t border-gray-800 pt-6">
                <a asp-action="Index" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-300 hover:bg-gray-50">Cancelar</a>
                <button type="submit" class="px-6 py-2 bg-pink-600 text-real-white rounded-lg hover:bg-pink-700 transition-colors shadow-md">
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
