@model manitaDeGatoWeb.Models.Estilista

@{
    ViewData["Title"] = "Nuevo Estilista";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-pink-500 hover:text-pink-600 flex items-center gap-2 font-medium">
            <i class="fa-solid fa-arrow-left"></i> Volver a estilistas
        </a>
    </div>

    <div class="neo-card rounded-2xl shadow-md border border-gray-800 p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-pink-900/20 rounded-bl-full -z-10"></div>
        
        <h1 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <div class="bg-pink-500/10 text-pink-500 p-2 rounded-lg">
                <i class="fa-solid fa-scissors"></i>
            </div>
            Registrar Profesional
        </h1>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            @if (ViewBag.Error != null)
            {
                <div class="mb-4 text-red-500 text-sm font-medium">@ViewBag.Error</div>
            }
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Nombre" class="block text-sm font-medium text-gray-300 mb-1">Nombre</label>
                    <input asp-for="Nombre" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Apellido" class="block text-sm font-medium text-gray-300 mb-1">Apellido</label>
                    <input asp-for="Apellido" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Rut" class="block text-sm font-medium text-gray-300 mb-1">RUT</label>
                    <input asp-for="Rut" id="Rut" required placeholder="12.345.678-9" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                    <span asp-validation-for="Rut" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label asp-for="Usuario" class="block text-sm font-medium text-gray-300 mb-1">Nombre de Usuario</label>
                    <input asp-for="Usuario" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
                <div>
                    <label asp-for="Contraseña" class="block text-sm font-medium text-gray-300 mb-1">Contraseña Inicial</label>
                    <input asp-for="Contraseña" type="password" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-3 border-t border-gray-800 pt-6">
                <a asp-action="Index" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-300 hover:bg-gray-500/10">Cancelar</a>
                <button type="submit" class="px-6 py-2 bg-pink-600 text-real-white rounded-lg hover:bg-pink-700 transition-colors shadow-md">
                    Registrar Estilista
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('Rut').addEventListener('input', function(e) {
            let value = e.target.value.replace(/[^0-9kK]/g, '').toUpperCase();
            if (value.length === 0) { e.target.value = ''; return; }
            let body = value.slice(0, -1);
            let digit = value.slice(-1);
            let formattedBody = '';
            for (let i = body.length - 1, j = 1; i >= 0; i--, j++) {
                formattedBody = body.charAt(i) + formattedBody;
                if (j % 3 === 0 && i !== 0) formattedBody = '.' + formattedBody;
            }
            if (value.length > 1) {
                e.target.value = formattedBody + '-' + digit;
            } else {
                e.target.value = value;
            }
        });
    </script>
}
