@model IEnumerable<manitaDeGatoWeb.Models.Estilista>

@{
    ViewData["Title"] = "Gestión de Estilistas";
}

<div class="mb-8 flex justify-between items-center">
    <div>
        <h1 class="text-3xl font-bold text-white">Personal de la Estética</h1>
        <p class="text-gray-400 mt-1">Administra a los estilistas registrados en el sistema.</p>
    </div>
    <a asp-action="Create" class="bg-pink-600 text-real-white px-6 py-2 rounded-lg hover:bg-pink-700 transition-colors shadow-md flex items-center gap-2">
        <i class="fa-solid fa-user-plus"></i> Registrar Estilista
    </a>
</div>



<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var item in Model)
    {
        <div class="neo-card rounded-2xl shadow-sm border border-gray-800 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-4 mb-3">
                <div class="w-16 h-16 bg-pink-500/10 rounded-full flex items-center justify-center text-pink-500 text-2xl font-bold shrink-0">
                    @(item.Nombre.Substring(0,1))@(item.Apellido?.Substring(0,1))
                </div>
                <div class="min-w-0">
                    <h3 class="text-lg font-bold text-white truncate">@item.Nombre @item.Apellido</h3>
                    <p class="text-sm text-gray-400">@@@item.Usuario</p>
                </div>
            </div>
            
            <div class="space-y-1.5 text-xs text-gray-400 mb-4 pl-1">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-envelope text-pink-500/70 w-4 text-center"></i>
                    <span class="truncate">@item.Correo</span>
                </div>
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-phone text-pink-500/70 w-4 text-center"></i>
                    <span>@item.Telefono</span>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4 border-t border-gray-800 pt-4 mt-4">
                <div class="text-center">
                    <p class="text-2xl font-bold text-pink-500">@(item.Servicios?.Count ?? 0)</p>
                    <p class="text-xs text-gray-400 uppercase font-semibold">Servicios</p>
                </div>
                <div class="text-center border-l border-gray-800">
                    <p class="text-2xl font-bold text-pink-500">@(item.Citas?.Count ?? 0)</p>
                    <p class="text-xs text-gray-400 uppercase font-semibold">Citas Total</p>
                </div>
            </div>

            <div class="border-t border-gray-800 pt-4 mt-4 flex justify-end items-center gap-2">
                <a asp-action="Horario" asp-route-id="@item.Id" class="text-sm text-pink-500 hover:text-pink-700 font-semibold flex items-center gap-1 transition-colors px-2.5 py-1.5 rounded-lg hover:bg-pink-500/10">
                    <i class="fa-solid fa-clock text-xs"></i> Horario
                </a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="text-sm text-pink-500 hover:text-pink-700 font-semibold flex items-center gap-1 transition-colors px-2.5 py-1.5 rounded-lg hover:bg-pink-500/10">
                    <i class="fa-solid fa-pen text-xs"></i> Editar
                </a>
                
                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline-block" onsubmit="return confirm('¿Seguro que deseas eliminar a este estilista? Se borrarán todos sus horarios, servicios exclusivos y citas asociadas.');">
                    <button type="submit" class="text-sm text-red-500 hover:text-red-700 font-semibold flex items-center gap-1 transition-colors bg-transparent border-none cursor-pointer px-2.5 py-1.5 rounded-lg hover:bg-red-500/10 focus:outline-none">
                        <i class="fa-solid fa-trash text-xs"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-span-full text-center py-12 neo-card rounded-xl border border-dashed border-gray-300">
            <i class="fa-solid fa-user-slash text-gray-300 text-5xl mb-3"></i>
            <h3 class="text-lg font-medium text-white">No hay estilistas registrados</h3>
            <p class="mt-1 text-gray-400">Aún no se ha agregado ningún estilista al sistema.</p>
        </div>
    }
</div>
