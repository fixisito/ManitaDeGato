@model IEnumerable<manitaDeGatoWeb.Models.Categoria>

@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="mb-8 flex justify-between items-center">
    <div>
        <h1 class="text-3xl font-bold text-white">Categorías de Servicio</h1>
        <p class="text-gray-400 mt-1">Organiza los servicios de tu estética.</p>
    </div>
    <a asp-action="Create" class="bg-pink-600 text-real-white px-6 py-2 rounded-lg hover:bg-pink-700 transition-colors shadow-md flex items-center gap-2">
        <i class="fa-solid fa-plus"></i> Nueva Categoría
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var item in Model)
    {
        <div class="neo-card rounded-2xl shadow-sm border border-gray-800 p-6 hover:shadow-md transition-shadow relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 bg-pink-900/20 rounded-bl-full -z-10 transition-transform group-hover:scale-110"></div>
            
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center text-pink-500 text-xl">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <h3 class="text-xl font-bold text-white">@item.Nombre</h3>
            </div>
            
            <p class="text-sm text-gray-400 mb-6 font-medium">
                Esta categoría tiene <span class="text-pink-500 font-bold">@(item.Servicios?.Count ?? 0)</span> servicios vinculados.
            </p>

            <div class="border-t border-gray-800 pt-4 flex justify-end gap-2">
                <a asp-action="Edit" asp-route-id="@item.Id" class="text-sm text-pink-600 hover:text-pink-800 font-medium flex items-center gap-1 transition-colors px-2 py-1">
                    <i class="fa-solid fa-pen"></i> Editar
                </a>
                
                @if (item.Servicios == null || item.Servicios.Count == 0)
                {
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar esta categoría?');">
                        <button type="submit" class="text-sm text-red-500 hover:text-red-700 font-medium flex items-center gap-1 transition-colors">
                            <i class="fa-solid fa-trash"></i> Eliminar
                        </button>
                    </form>
                }
                else
                {
                    <span class="text-xs text-gray-400" title="No puedes eliminar categorías con servicios asignados">
                        <i class="fa-solid fa-lock mr-1"></i> Protegida
                    </span>
                }
            </div>
        </div>
    }
</div>
