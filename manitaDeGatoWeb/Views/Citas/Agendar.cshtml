@model manitaDeGatoWeb.Models.Cita

@{
    ViewData["Title"] = "Agendar Cita";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Historial" class="text-pink-500 hover:text-pink-600 flex items-center gap-2 font-medium">
            <i class="fa-solid fa-arrow-left"></i> Volver a mis citas
        </a>
    </div>

    <div class="neo-card rounded-2xl shadow-md border border-gray-800 p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-pink-900/20 rounded-bl-full -z-10"></div>
        
        <h1 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
            <div class="bg-pink-500/10 text-pink-500 p-2 rounded-lg">
                <i class="fa-solid fa-calendar-plus"></i>
            </div>
            Reserva tu Cita
        </h1>
        <p class="text-gray-400 mb-6 ml-12">Elige la categoría, tu estilista favorito y el horario que mejor te acomode.</p>

        <form asp-action="Agendar">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- CATEGORÍA -->
                <div class="col-span-1 md:col-span-2">
                    <label for="IdCategoria" class="block text-sm font-medium text-gray-300 mb-1">1. Categoría del servicio</label>
                    <div class="relative">
                        <select id="IdCategoria" class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none">
                            <option value="">-- Selecciona una categoría --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-layer-group text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- ESTILISTA -->
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="IdEstilista" class="block text-sm font-medium text-gray-300 mb-1">2. Estilista de preferencia</label>
                    <div class="relative">
                        <select asp-for="IdEstilista" disabled class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none disabled:opacity-50 disabled:cursor-not-allowed">
                            <option value="">-- Primero selecciona una categoría --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-scissors text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="IdEstilista" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- SERVICIO -->
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="IdServicio" class="block text-sm font-medium text-gray-300 mb-1">3. Servicio a realizar</label>
                    <div class="relative">
                        <select asp-for="IdServicio" disabled class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none disabled:opacity-50 disabled:cursor-not-allowed">
                            <option value="">-- Luego selecciona tu estilista --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-bell-concierge text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="IdServicio" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- FECHA -->
                <div>
                    <label asp-for="FechaCita" class="block text-sm font-medium text-gray-300 mb-1">Día de la cita</label>
                    <div class="relative">
                        <input asp-for="FechaCita" type="date" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500 bg-white/50 dark:bg-gray-800/50" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <span asp-validation-for="FechaCita" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- HORA -->
                <div>
                    <label asp-for="HoraCita" class="block text-sm font-medium text-gray-300 mb-1">Hora de la cita</label>
                    <div class="relative">
                        <select asp-for="HoraCita" class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none">
                            <option value="">-- Hora --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-clock text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="HoraCita" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-800 flex items-center justify-between">
                <p class="text-sm text-gray-400 flex items-center gap-2">
                    <i class="fa-solid fa-circle-info text-pink-400"></i>
                    Recibirás confirmación inmediata
                </p>
                <button type="submit" class="px-8 py-3 bg-pink-600 text-real-white rounded-lg hover:bg-pink-700 transition-all shadow-lg hover:shadow-xl font-medium text-lg flex items-center gap-2">
                    Confirmar Reserva <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const categorias = @Html.Raw(ViewBag.CategoriasJson);
            const estilistas = @Html.Raw(ViewBag.EstilistasJson);
            const servicios = @Html.Raw(ViewBag.ServiciosJson);

            const selCategoria = document.getElementById('IdCategoria');
            const selEstilista = document.getElementById('IdEstilista');
            const selServicio = document.getElementById('IdServicio');
            const selHora = document.getElementById('HoraCita');

            // 1. Cargar Categorías
            categorias.forEach(c => {
                selCategoria.add(new Option(c.Nombre, c.Id));
            });

            // 2. Cargar Bloques de Horas (10:00 a 20:30)
            for(let hour = 10; hour <= 20; hour++) {
                let hString = hour.toString().padStart(2, '0');
                selHora.add(new Option(`${hString}:00`, `${hString}:00:00`));
                if(hour < 21) {
                    selHora.add(new Option(`${hString}:30`, `${hString}:30:00`));
                }
            }

            // 3. Lógica Cascada: Categoría -> Estilista
            selCategoria.addEventListener('change', function() {
                selEstilista.disabled = true;
                selServicio.disabled = true;
                selEstilista.innerHTML = '<option value="">-- Selecciona tu estilista --</option>';
                selServicio.innerHTML = '<option value="">-- Luego selecciona el servicio --</option>';

                const catId = this.value;
                if(catId) {
                    estilistas.forEach(e => {
                        selEstilista.add(new Option(e.Nombre, e.Id));
                    });
                    selEstilista.disabled = false;
                }
            });

            // 4. Lógica Cascada: Estilista -> Servicio
            selEstilista.addEventListener('change', function() {
                selServicio.disabled = true;
                selServicio.innerHTML = '<option value="">-- Selecciona el servicio --</option>';
                
                const catId = parseInt(selCategoria.value);
                const estId = parseInt(this.value);

                if(catId && estId) {
                    // Filtrar servicios de la categoría elegida, que sean globales o del estilista
                    const serviciosFiltrados = servicios.filter(s => 
                        s.IdCategoria === catId && 
                        (s.IdEstilista === null || s.IdEstilista === estId)
                    );

                    serviciosFiltrados.forEach(s => {
                        selServicio.add(new Option(s.Nombre, s.Id));
                    });
                    
                    if(serviciosFiltrados.length === 0) {
                        selServicio.innerHTML = '<option value="">-- No hay servicios disponibles --</option>';
                    } else {
                        selServicio.disabled = false;
                    }
                }
            });
        });
    </script>
}
