@model manitaDeGatoWeb.Models.Cita

@{
    ViewData["Title"] = "Agendar Cita";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Historial" class="text-pink-500 hover:text-pink-600 flex items-center gap-2 font-medium">
            <i class="fa-solid fa-arrow-left"></i> Volver a mis citas
        </a>
    </div>

    <div class="neo-card rounded-2xl shadow-md border border-gray-800 p-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-pink-900/20 rounded-bl-full -z-10"></div>
        
        <h1 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
            <div class="bg-pink-500/10 text-pink-500 p-2 rounded-lg">
                <i class="fa-solid fa-calendar-plus"></i>
            </div>
            Reserva tu Cita
        </h1>
        <p class="text-gray-400 mb-6 ml-12">Elige el servicio, tu estilista favorito y el horario que mejor te acomode.</p>

        <form asp-action="Agendar">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="IdServicio" class="block text-sm font-medium text-gray-300 mb-1">Servicio a realizar</label>
                    <div class="relative">
                        <select asp-for="IdServicio" class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none" asp-items="ViewBag.IdServicio">
                            <option value="">-- Selecciona el servicio --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-bell-concierge text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="IdServicio" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="col-span-1 md:col-span-2">
                    <label asp-for="IdEstilista" class="block text-sm font-medium text-gray-300 mb-1">Estilista de preferencia</label>
                    <div class="relative">
                        <select asp-for="IdEstilista" class="w-full pl-10 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white/50 dark:bg-gray-800/50 focus:ring-pink-500 focus:border-pink-500 appearance-none" asp-items="ViewBag.IdEstilista">
                            <option value="">-- Selecciona tu estilista --</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-scissors text-gray-400"></i>
                        </div>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="IdEstilista" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="FechaCita" class="block text-sm font-medium text-gray-300 mb-1">Día de la cita</label>
                    <div class="relative">
                        <input asp-for="FechaCita" type="date" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <span asp-validation-for="FechaCita" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="HoraCita" class="block text-sm font-medium text-gray-300 mb-1">Hora de la cita</label>
                    <div class="relative">
                        <input asp-for="HoraCita" type="time" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" />
                    </div>
                    <span asp-validation-for="HoraCita" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-800 flex items-center justify-between">
                <p class="text-sm text-gray-400 flex items-center gap-2">
                    <i class="fa-solid fa-circle-info text-pink-400"></i>
                    Recibirás confirmación inmediata
                </p>
                <button type="submit" class="px-8 py-3 bg-pink-600 text-real-white rounded-lg hover:bg-pink-700 transition-all shadow-lg hover:shadow-xl font-medium text-lg flex items-center gap-2">
                    Confirmar Reserva <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
