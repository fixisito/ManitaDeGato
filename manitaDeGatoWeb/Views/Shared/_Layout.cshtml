<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manita De Gato</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
        /* Custom Tailwind Configuration for Theme Colors */
        :root {
            --brand-primary: #ec4899; /* pink-500 */
            --brand-dark: #1f2937;    /* gray-800 */
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6; /* gray-100 */
        }
        .glass-effect {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body class="flex flex-col min-h-screen text-gray-800 antialiased">
    
    <!-- Navbar -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-cat text-pink-500 text-2xl"></i>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="font-bold text-xl tracking-tight text-gray-900">
                    ManitaDe<span class="text-pink-500">Gato</span>
                </a>
            </div>
            
            <div class="flex items-center gap-4">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-sm text-gray-500 hidden md:block">Hola, @User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value</span>
                    <a asp-controller="Auth" asp-action="Logout" class="text-sm font-medium text-gray-600 hover:text-pink-500 transition-colors">
                        <i class="fa-solid fa-right-from-bracket mr-1"></i> Salir
                    </a>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="text-sm font-medium bg-pink-500 text-white px-4 py-2 rounded-full hover:bg-pink-600 transition-colors shadow-md">
                        Iniciar Sesión
                    </a>
                }
            </div>
        </nav>
    </header>

    <div class="flex-grow flex w-full">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <!-- Sidebar -->
            <aside class="w-64 bg-white border-r border-gray-200 hidden md:block flex-shrink-0">
                <div class="py-6 px-4 space-y-2">
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4 px-3">Menú Principal</div>
                    
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                        <i class="fa-solid fa-house w-5 text-center"></i> Inicio
                    </a>

                    @if (User.IsInRole("Administrador"))
                    {
                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-4 px-3">Gestión del Sistema</div>
                        <a asp-controller="Estilistas" asp-action="Index" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-users w-5 text-center"></i> Personal
                        </a>
                        <a asp-controller="Categorias" asp-action="Index" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-layer-group w-5 text-center"></i> Categorías
                        </a>
                        <a asp-controller="Servicios" asp-action="Index" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-bell-concierge w-5 text-center"></i> Servicios
                        </a>
                        <a asp-controller="Citas" asp-action="Index" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-calendar-days w-5 text-center"></i> Todas las Citas
                        </a>
                    }
                    else if (User.IsInRole("Estilista"))
                    {
                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-4 px-3">Mi Espacio</div>
                        <a asp-controller="Servicios" asp-action="MisServicios" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-scissors w-5 text-center"></i> Mis Servicios
                        </a>
                        <a asp-controller="Citas" asp-action="MisCitas" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-calendar-check w-5 text-center"></i> Mi Agenda
                        </a>
                    }
                    else if (User.IsInRole("Cliente"))
                    {
                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-4 px-3">Reservaciones</div>
                        <a asp-controller="Citas" asp-action="Agendar" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-calendar-plus w-5 text-center"></i> Agendar Cita
                        </a>
                        <a asp-controller="Citas" asp-action="Historial" class="flex items-center gap-3 px-3 py-2 rounded-lg text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition-colors font-medium">
                            <i class="fa-solid fa-clock-rotate-left w-5 text-center"></i> Mis Citas
                        </a>
                    }
                </div>
            </aside>
        }

        <main role="main" class="flex-grow p-6 md:p-8 w-full max-w-7xl mx-auto">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-t border-gray-200 mt-auto">
        <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
            <p class="text-center text-sm text-gray-500">&copy; 2026 - ManitaDeGato - Sistema de Citas</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
