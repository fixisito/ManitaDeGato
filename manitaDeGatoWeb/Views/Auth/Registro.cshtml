@model manitaDeGatoWeb.Models.Cliente

@{
    ViewData["Title"] = "Regístrate";
    Layout = "_Layout";
}

<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 neo-card p-10 rounded-2xl shadow-xl border border-pink-500/20 relative overflow-hidden">
        
        <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-pink-500/10 opacity-50"></div>
        <div class="absolute bottom-0 left-0 -ml-8 -mb-8 w-24 h-24 rounded-full bg-pink-500/20 opacity-50"></div>

        <div class="relative z-10">
            <div class="text-center">
                <i class="fa-solid fa-user-plus text-pink-500 text-5xl mb-4"></i>
                <h2 class="mt-2 text-3xl font-black text-white tracking-tight">
                    Crea tu cuenta
                </h2>
                <p class="mt-2 text-sm text-gray-400">
                    Únete a Manita De Gato y agenda tus citas fácilmente
                </p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="mt-4 border-l-2 border-red-500 pl-4 py-2 bg-red-500/10">
                    <p class="text-xs font-mono text-red-400 tracking-wider">[ERROR] @ViewBag.Error</p>
                </div>
            }

            <form class="mt-8 space-y-6" asp-action="Registro" method="POST">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                
                <div class="space-y-4">
                    <div>
                        <label asp-for="Nombre" class="block text-sm font-medium text-gray-300 mb-1">Nombre Completo</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fa-solid fa-address-card text-gray-400"></i>
                            </div>
                            <input asp-for="Nombre" required class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-400 text-white focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm" placeholder="Ej. Ana García">
                        </div>
                        <span asp-validation-for="Nombre" class="text-red-500 text-xs"></span>
                    </div>

                    <div>
                        <label asp-for="Usuario" class="block text-sm font-medium text-gray-300 mb-1">Nombre de Usuario</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fa-solid fa-user text-gray-400"></i>
                            </div>
                            <input asp-for="Usuario" required class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-400 text-white focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm" placeholder="ana_garcia">
                        </div>
                        <span asp-validation-for="Usuario" class="text-red-500 text-xs"></span>
                    </div>

                    <div>
                        <label asp-for="Contraseña" class="block text-sm font-medium text-gray-300 mb-1">Contraseña</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fa-solid fa-lock text-gray-400"></i>
                            </div>
                            <input asp-for="Contraseña" type="password" required class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-400 text-white focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm" placeholder="••••••••">
                        </div>
                        <span asp-validation-for="Contraseña" class="text-red-500 text-xs"></span>
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-real-white bg-pink-600 hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 transition-all shadow-md hover:shadow-lg">
                        Registrarme
                    </button>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    ¿Ya tienes cuenta? 
                    <a asp-action="Login" class="font-medium text-pink-600 hover:text-pink-500">Inicia Sesión</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
