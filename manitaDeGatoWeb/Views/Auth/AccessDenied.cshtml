@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="min-h-[60vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full text-center space-y-8 neo-card p-10 rounded-2xl shadow-xl border border-red-100">
        <i class="fa-solid fa-ban text-red-500 text-6xl mb-4"></i>
        <h2 class="mt-2 text-3xl font-extrabold text-white tracking-tight">
            Acceso Denegado
        </h2>
        <p class="mt-2 text-sm text-gray-400">
            No tienes los permisos necesarios para ver esta página o realizar esta acción.
        </p>
        <div class="mt-6">
            <a asp-controller="Home" asp-action="Index" class="inline-flex justify-center items-center py-3 px-6 border border-transparent text-sm font-medium rounded-lg text-real-white bg-pink-600 hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 transition-all shadow-md hover:shadow-lg">
                <i class="fa-solid fa-arrow-left mr-2"></i> Volver al Inicio
            </a>
        </div>
    </div>
</div>
