@model manitaDeGatoWeb.Models.Servicio

@{
    ViewData["Title"] = "Nuevo Servicio";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a asp-action="Index" class="text-pink-500 hover:text-pink-600 flex items-center gap-2 font-medium">
            <i class="fa-solid fa-arrow-left"></i> Volver a la lista
        </a>
    </div>

    <div class="neo-card rounded-2xl shadow-md border border-gray-800 p-8 relative overflow-hidden">
        <!-- Decoración -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-pink-900/20 rounded-bl-full -z-10"></div>
        
        <h1 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <div class="bg-pink-500/10 text-pink-500 p-2 rounded-lg">
                <i class="fa-solid fa-bell-concierge"></i>
            </div>
            Registrar Nuevo Servicio
        </h1>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 text-sm"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-1 md:col-span-2">
                    <label asp-for="Nombre" class="block text-sm font-medium text-gray-300 mb-1">Nombre del Servicio</label>
                    <input asp-for="Nombre" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" placeholder="Ej. Corte de cabello mujer" />
                    <span asp-validation-for="Nombre" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Id_categoria" class="block text-sm font-medium text-gray-300 mb-1">Categoría</label>
                    <select asp-for="Id_categoria" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" asp-items="ViewBag.Id_categoria">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="Id_categoria" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Duracion" class="block text-sm font-medium text-gray-300 mb-1">Duración del Servicio</label>
                    <div class="relative">
                        <select asp-for="Duracion" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500 pl-10">
                            <option value="30">30 minutos (1 bloque)</option>
                            <option value="60">60 minutos (2 bloques)</option>
                            <option value="90">90 minutos (3 bloques)</option>
                            <option value="120">120 minutos (4 bloques)</option>
                            <option value="150">150 minutos (5 bloques)</option>
                            <option value="180">180 minutos (6 bloques)</option>
                        </select>
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-regular fa-clock text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="Duracion" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Precio" class="block text-sm font-medium text-gray-300 mb-1">Precio Neto ($)</label>
                    <div class="relative">
                        <input asp-for="Precio" type="number" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500 pl-10" />
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-dollar-sign text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="Precio" class="text-red-500 text-xs mt-1"></span>
                    <p class="text-xs text-pink-500 mt-2 font-medium">El IVA (19%) se calculará automáticamente.</p>
                </div>

                <div class="col-span-1 md:col-span-2">
                    <label asp-for="Descripcion" class="block text-sm font-medium text-gray-300 mb-1">Descripción</label>
                    <textarea asp-for="Descripcion" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500"></textarea>
                    <span asp-validation-for="Descripcion" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-3 border-t border-gray-800 pt-6">
                <a asp-action="Index" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-300 hover:bg-gray-500/10 transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="px-6 py-2 bg-pink-600 text-real-white rounded-lg hover:bg-pink-700 transition-colors shadow-md">
                    <i class="fa-solid fa-save mr-2"></i> Guardar Servicio
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
